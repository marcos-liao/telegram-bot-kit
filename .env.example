# --- Required ---
# Telegram bot token from @BotFather.
TELEGRAM_TOKEN=

# --- Bot identity (used by /name, /owner, /skill) ---
# BOT_SKILL supports \n for line breaks. Leave any of these unset to use the
# built-in generic defaults.
BOT_NAME=
BOT_OWNER=
BOT_SKILL=

# --- LLM backend (any OpenAI-compatible endpoint) ---
# Ollama's OpenAI-compatible endpoint is http://<host>:11434/v1 — use that if
# you're running Ollama locally (see docker-compose.ollama.yml for a bundled
# option). Or point this at OpenAI, Groq, OpenRouter, etc.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1

# Embeddings power long-term memory + per-chat document search. Not every
# OpenAI-compatible provider offers embeddings, so these are independently
# configurable; they default to the LLM_* values above if unset.
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=nomic-embed-text

# --- Web search (SearXNG) ---
# `docker compose up` runs a bundled SearXNG for you and overrides this
# automatically (see docker-compose.yml). Only edit this if you're running
# bot.py directly (no Docker) against your own SearXNG instance.
SEARXNG_URL=http://127.0.0.1:8888

# --- Diagram rendering (Kroki) ---
# Same deal: `docker compose up` bundles Kroki + a Mermaid companion and
# overrides this automatically. Only edit this for a non-Docker run.
KROKI_URL=http://127.0.0.1:8001

# --- Storage ---
DB_PATH=./memory.db
SYSTEM_PROMPT_PATH=./system_prompt.txt

# --- Admins (comma-separated Telegram user IDs) ---
# Grants access to /whois, /restart_bot, /users, and admin command menu.
ADMIN_IDS=

# --- Conversation memory tuning (defaults are usually fine) ---
RECENT_MESSAGES=12
SUMMARIZE_AFTER=24
MAX_TOOL_ITERS=6
SEARCH_RESULTS=5
HTTP_TIMEOUT=120
MEMORY_TOPK=3
MEMORY_MIN_SIM=0.60
MEMORY_MAX_PER_CHAT=2000
MEMORY_RETENTION_DAYS=180
EMBED_QUERY_PREFIX=search_query:
EMBED_DOC_PREFIX=search_document:

# --- Per-chat document upload/QA tuning ---
CHATDOC_MAX_INGEST=150
CHATDOC_MAX_PER_CHAT=600
CHATDOC_TOPK=5
CHATDOC_MIN_SIM=0.40
MAX_UPLOAD_MB=20

# --- Document text-extraction tuning (doc_extract.py) ---
DOC_OCR=1
OCR_LANG=eng
OCR_MAX_PAGES=40
PDF_MIN_TEXT=120
DOC_CHUNK_SIZE=900
DOC_CHUNK_OVERLAP=150
